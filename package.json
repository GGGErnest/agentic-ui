{
  "name": "agentic-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "backend:dev": "tsx watch projects/backend/src/server.ts",
    "backend:build": "tsc -p projects/backend/tsconfig.json",
    "backend:start": "node dist/backend/server.js",
    "backend:test": "vitest run --config projects/backend/vitest.config.ts",
    "litellm:up": "docker compose -f docker-compose.litellm.yml up -d",
    "litellm:down": "docker compose -f docker-compose.litellm.yml down",
    "litellm:logs": "docker compose -f docker-compose.litellm.yml logs -f litellm",
    "verify:litellm-demo": "npm run backend:test && ng build agentic-ui && ng test demo --watch=false && ng build demo --configuration development"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/supertest": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.5",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "supertest": "^6.3.3",
    "tsx": "^4.7.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
