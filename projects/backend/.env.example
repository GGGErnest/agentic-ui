BACKEND_PORT=3000
DEMO_CORS_ORIGIN=http://localhost:4200
DEMO_CLIENT_TOKEN=agentic-ui-demo
LITELLM_BASE_URL=http://localhost:8000/v1
LITELLM_API_KEY=litellm-local-key
# Set to one of the models in litellm.config.yaml:
#   agentic-demo              → Ollama (local llama3.2)
#   openrouter/gemini-flash-lite  → OpenRouter (cloud, needs OPENROUTER_API_KEY)
#   openrouter/gemini-flash   → OpenRouter (cloud, needs OPENROUTER_API_KEY)
LITELLM_MODEL=openrouter/gemini-flash-lite
OPENROUTER_API_KEY=sk-or-v1-...
OLLAMA_API_BASE=http://host.docker.internal:11434
