{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/backend",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vitest/globals"],
    "esModuleInterop": true,
    "noEmit": false
  },
  "include": ["src/**/*.ts"]
}
